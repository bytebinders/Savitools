# ─── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_PREFIX=api

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/savitools

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stellar ───────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# ─── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=your-signing-secret-here

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
WEB_ORIGIN=http://localhost:3000

# Fluxa SSO — optional in development (mock tenant IDs are used when unset)
FLUXA_API_URL=https://api.fluxa.io

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_STELLAR_NETWORK=testnet
